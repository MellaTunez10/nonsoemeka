# =============================================================================
# Nonsoemeka Pharmacy — Environment Variables
# Copy this file to .env and fill in all required values before running:
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# --- Database -----------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=changeme_strong_db_password
DB_NAME=nonsoemeka

# --- JWT Secrets (REQUIRED — MUST be changed for production) ------------------
# Generate with:  openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Server -------------------------------------------------------------------
# Port the nginx frontend is exposed on (default 80)
APP_PORT=80

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# --- CORS (REQUIRED) ----------------------------------------------------------
# Set to your production domain. For local dev use http://localhost.
# Examples:
#   ALLOWED_ORIGINS=https://pos.nonsoemeka.com
#   ALLOWED_ORIGINS=http://localhost          (dev only)
ALLOWED_ORIGINS=http://localhost

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_GLOBAL_PER_MINUTE=300

# --- Frontend API Base URL (optional) ----------------------------------------
# Leave empty for same-origin nginx deployments (the default).
# Set to your backend URL only if the frontend is hosted on a different domain
# (e.g. Vercel) and the Go API is on a separate host (e.g. fly.io).
# Example: VITE_API_BASE_URL=https://api.your-pharmacy.com
VITE_API_BASE_URL=
