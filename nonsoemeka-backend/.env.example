SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=15s

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nonsoemeka_db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=15m

JWT_ACCESS_SECRET=your-production-jwt-access-secret-key-min32chars
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-key-min32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

LOG_LEVEL=info
LOG_FORMAT=json

RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_GLOBAL_PER_MINUTE=300

# REQUIRED: Set to your production domain (e.g. https://pos.nonsoemeka.com)
# For local dev: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
